{
  "name": "academic-service",
  "version": "1.0.0",
  "description": "Academic microservice for School ERP",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "schema": "psql -U postgres -h localhost -d academic_db -f schema.sql",
    "seed": "npm run schema && psql -U postgres -h localhost -d academic_db -f seed.sql"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
